# 知知 服务端配置
# 复制为 .env 并填入实际值

PORT=3000
DATABASE_URL=postgres://postgres:postgres@localhost:5432/command_center?sslmode=disable
REDIS_URL=redis://localhost:6379

# JWT 签名密钥（生产环境必须替换为随机字符串）
JWT_SECRET=dev-secret-change-me

# 大模型 API Key（至少填一个）
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=

# 短信服务 (mock = 控制台打印验证码, tencent = 腾讯云短信)
SMS_PROVIDER=mock
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=
TENCENT_SMS_SDK_APP_ID=
TENCENT_SMS_SIGN_NAME=
TENCENT_SMS_TEMPLATE_ID=

# 语音转写 (mock = 固定文本, tencent = 腾讯云 ASR)
ASR_PROVIDER=mock

# 账号凭据加密密钥（必须 32 字符）
ACCOUNT_ENCRYPT_KEY=dev-encrypt-key-change-me-32chr

# 上传文件目录
UPLOAD_DIR=./uploads
